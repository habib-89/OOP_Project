<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.filesystemclientfx.DashboardController"
            prefWidth="1200.0" prefHeight="720.0"
            styleClass="root-dark">

    <left>
        <VBox spacing="0.0" styleClass="sidebar" prefWidth="210.0">
            <children>
                <VBox styleClass="sidebar-brand">
                    <children>
                        <Label text="FILEVAULT" styleClass="brand-title"/>
                    </children>
                </VBox>

                <VBox styleClass="user-info" spacing="8.0">
                    <children>
                        <Label text="USER" styleClass="nav-section-label"/>
                        <Label fx:id="welcomeLabel" text="username" styleClass="user-name"/>
                    </children>
                </VBox>

                <VBox styleClass="nav-section" spacing="4.0">
                    <children>
                        <Label text="NAVIGATION" styleClass="nav-section-label"/>
                        <Button fx:id="navFilesBtn" text="📁  My Files" onAction="#handleNavFiles" styleClass="nav-btn nav-btn-active" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="navSharedBtn" text="📤  Shared" onAction="#handleNavShared" styleClass="nav-btn" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="navGroupsBtn" text="👥  Groups" onAction="#handleNavGroups" styleClass="nav-btn" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="navRecycleBtn" text="🗑  Recycle Bin" onAction="#handleNavRecycleBin" styleClass="nav-btn" maxWidth="1.7976931348623157E308"/>
                        <Button fx:id="navAdminBtn" text="🛠  Admin" onAction="#handleNavAdmin" styleClass="nav-btn" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox styleClass="sidebar-bottom" spacing="8.0">
                    <children>
                        <Button fx:id="themeToggleBtn" text="☀ Light Mode" onAction="#handleThemeToggle" styleClass="theme-btn" maxWidth="1.7976931348623157E308"/>
                        <Button text="↩ Logout" onAction="#handleLogout" styleClass="logout-btn" maxWidth="1.7976931348623157E308"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <BorderPane styleClass="main-content">
            <top>
                <VBox>
                    <children>
                        <HBox fx:id="searchBar" styleClass="top-bar" alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label fx:id="pathLabel" text="/ Home" styleClass="path-label"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="statusLabel" text="Ready." styleClass="status-label"/>
                            </children>
                        </HBox>

                        <HBox styleClass="search-bar" spacing="8.0" alignment="CENTER_LEFT">
                            <children>
                                <TextField fx:id="searchField" promptText="Search files..." onAction="#handleSearch" styleClass="search-input" HBox.hgrow="ALWAYS"/>
                                <Button text="Search" onAction="#handleSearch" styleClass="action-btn-small"/>
                                <Button text="Refresh" onAction="#handleRefresh" styleClass="action-btn-small"/>
                            </children>
                        </HBox>

                        <HBox fx:id="actionBar" styleClass="action-bar" spacing="8.0" alignment="CENTER_LEFT">
                            <children>
                                <Button text="⬆ Upload" onAction="#handleUpload" styleClass="action-btn-primary"/>
                                <Button text="⬇ Download" onAction="#handleDownload" styleClass="action-btn"/>
                                <Button text="📁 Folder" onAction="#handleCreateFolder" styleClass="action-btn"/>
                                <Button text="✏ Rename" onAction="#handleRename" styleClass="action-btn"/>
                                <Button text="📦 Move" onAction="#handleMoveFile" styleClass="action-btn"/>
                                <Button text="📤 Share / Add Member" onAction="#handleShare" styleClass="action-btn"/>
                                <Button text="🗑 Delete" onAction="#handleDelete" styleClass="action-btn-danger"/>
                                <Button text="⬅ Up" onAction="#handleGoUp" styleClass="action-btn-small"/>
                                <Button text="⭐ Bookmark" onAction="#handleAddBookmark" styleClass="action-btn-small"/>
                                <Button text="👥 Create Group" onAction="#handleCreateGroup" styleClass="action-btn-small"/>
                                <Button text="➕ Add Group Member" onAction="#handleAddGroupMember" styleClass="action-btn-small"/>
                                <Button fx:id="sortBtn" text="↕ Sort" onAction="#handleSort" styleClass="action-btn-small"/>
                            </children>
                        </HBox>

                        <HBox fx:id="bookmarkButtonsBox" spacing="6.0">
                            <padding>
                                <Insets top="8.0" right="24.0" bottom="8.0" left="24.0"/>
                            </padding>
                        </HBox>

                        <HBox spacing="6.0">
                            <padding>
                                <Insets top="0.0" right="24.0" bottom="0.0" left="24.0"/>
                            </padding>
                            <children>
                                <Button text="+ New Tab" onAction="#handleNewTab" styleClass="action-btn-small"/>
                                <HBox fx:id="tabButtonsBox" spacing="6.0"/>
                            </children>
                        </HBox>

                        <VBox spacing="4.0">
                            <padding>
                                <Insets top="4.0" right="24.0" bottom="4.0" left="24.0"/>
                            </padding>
                            <children>
                                <ProgressBar fx:id="uploadProgressBar" visible="false" managed="false" prefWidth="500.0" styleClass="upload-progress"/>
                                <Label fx:id="progressLabel" text="Progress" visible="false" managed="false" styleClass="progress-label"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </top>

            <center>
                <HBox spacing="0.0">
                    <children>
                        <VBox fx:id="tableContainer" HBox.hgrow="ALWAYS" spacing="0.0">
                            <padding>
                                <Insets top="8.0" right="0.0" bottom="8.0" left="24.0"/>
                            </padding>
                        </VBox>

                        <VBox prefWidth="300.0" styleClass="preview-panel" spacing="14.0">
                            <children>
                                <Label text="PREVIEW" styleClass="preview-title"/>
                                <HBox fx:id="fileView" alignment="CENTER">
                                    <children>
                                        <VBox spacing="12.0" alignment="TOP_CENTER">
                                            <children>
                                                <ImageView fx:id="imagePreview" fitWidth="240.0" fitHeight="260.0" preserveRatio="true" visible="false"/>
                                                <Label fx:id="previewLabel" text="Select a file to preview" wrapText="true" styleClass="preview-hint"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox fx:id="videoView" visible="false" managed="false" spacing="10.0">
                                    <children>
                                        <Label fx:id="videoTitleLabel" text="Video" styleClass="path-label"/>
                                        <MediaView fx:id="mediaView" fitWidth="260.0" fitHeight="220.0" preserveRatio="true"/>
                                        <HBox spacing="6.0" alignment="CENTER">
                                            <children>
                                                <Button text="⏪ 10s" onAction="#handleVideoRewind" styleClass="action-btn-small"/>
                                                <Button fx:id="playPauseBtn" text="▶" onAction="#handleVideoPlayPause" styleClass="action-btn-small"/>
                                                <Button text="10s ⏩" onAction="#handleVideoForward" styleClass="action-btn-small"/>
                                                <Button fx:id="muteBtn" text="🔊" onAction="#handleVideoMute" styleClass="action-btn-small"/>
                                            </children>
                                        </HBox>
                                        <Slider fx:id="seekSlider"/>
                                        <HBox spacing="8.0" alignment="CENTER">
                                            <children>
                                                <Label fx:id="currentTimeLabel" text="00:00" styleClass="status-label"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label text="Volume" styleClass="status-label"/>
                                                <Slider fx:id="volumeSlider" prefWidth="90.0" value="70.0"/>
                                                <Label fx:id="totalTimeLabel" text="00:00" styleClass="status-label"/>
                                            </children>
                                        </HBox>
                                        <Button text="← Back to Files" onAction="#handleBackFromVideo" styleClass="action-btn-small"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>
