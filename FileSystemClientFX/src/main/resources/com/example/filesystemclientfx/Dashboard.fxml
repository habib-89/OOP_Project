<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.media.*?>
<?import javafx.scene.web.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.filesystemclientfx.DashboardController"
            styleClass="root-dark">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="200">
            <VBox styleClass="sidebar-brand" alignment="CENTER">
                <Label text="⬡ FileVault" styleClass="brand-title"/>
            </VBox>
            <VBox styleClass="user-info" alignment="CENTER" spacing="8">
                <StackPane>
                    <Circle fx:id="profileBorderCircle" radius="36" fill="TRANSPARENT" stroke="#00d4ff" strokeWidth="3"/>
                    <ImageView fx:id="profileImageView" fitWidth="64" fitHeight="64" preserveRatio="true"/>
                    <Label text="👤" styleClass="user-avatar-fallback" mouseTransparent="true"/>
                </StackPane>
                <Label fx:id="welcomeLabel" text="Welcome!" styleClass="user-name"/>
                <Button fx:id="changeProfilePicBtn" text="Change Picture" onAction="#handleChangeProfilePicture"
                        styleClass="action-btn-small"/>
            </VBox>
            <VBox styleClass="nav-section" spacing="4">
                <Label text="NAVIGATION" styleClass="nav-section-label"/>
                <Button text="🏠  My Files" onAction="#handleNavFiles"
                        styleClass="nav-btn, nav-btn-active" maxWidth="Infinity"
                        fx:id="navFilesBtn"/>
                <Button text="🗑  Recycle Bin" onAction="#handleNavRecycleBin"
                        styleClass="nav-btn" maxWidth="Infinity" fx:id="navRecycleBtn"/>
                <Button text="📤 Shared with Me" onAction="#handleNavShared"
                        styleClass="nav-btn" maxWidth="Infinity" fx:id="navSharedBtn"/>
                <Button text="👥 Groups" onAction="#handleNavGroups"
                        styleClass="nav-btn" maxWidth="Infinity" fx:id="navGroupsBtn"/>
                <Button text="👑 Admin Panel" onAction="#handleNavAdmin"
                        styleClass="nav-btn" maxWidth="Infinity"
                        fx:id="navAdminBtn" visible="false" managed="false"/>
            </VBox>
            <Pane VBox.vgrow="ALWAYS"/>
            <VBox styleClass="sidebar-bottom" spacing="8">
                <Button fx:id="themeToggleBtn" text="☀ Light Mode"
                        onAction="#handleThemeToggle" styleClass="theme-btn" maxWidth="Infinity"/>
                <Button text="⇥  Logout" onAction="#handleLogout"
                        styleClass="logout-btn" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox styleClass="main-content" spacing="0">

            <!-- Top bar -->
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="15">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="pathLabel" text="/ Home" styleClass="path-label"/>
                    <Label fx:id="statusLabel" text="" styleClass="status-label"/>
                </VBox>
                <Button text="⬆ Up" onAction="#handleGoUp"
                        styleClass="action-btn-small" fx:id="goUpBtn"/>
                <Button text="↻ Refresh" onAction="#handleRefresh"
                        styleClass="action-btn-small" fx:id="refreshBtn"/>
            </HBox>

            <!-- TAB BAR -->
            <HBox fx:id="tabBar" spacing="0" alignment="CENTER_LEFT" styleClass="tab-bar">
                <HBox fx:id="tabButtonsBox" spacing="3" alignment="CENTER_LEFT"/>
                <Button text="＋" onAction="#handleNewTab" styleClass="tab-add-btn"/>
            </HBox>

            <!-- Search bar -->
            <HBox styleClass="search-bar" spacing="10" alignment="CENTER_LEFT" fx:id="searchBar">
                <TextField fx:id="searchField"
                           promptText="🔍  Search files and folders..."
                           styleClass="search-input" HBox.hgrow="ALWAYS"
                           onKeyReleased="#handleSearch"/>
            </HBox>

            <!-- Action buttons -->
            <HBox styleClass="action-bar" spacing="8" alignment="CENTER_LEFT" fx:id="actionBar">
                <Button text="📁 New Folder" onAction="#handleCreateFolder" styleClass="action-btn"/>
                <Button text="⬆ Upload" onAction="#handleUpload" styleClass="action-btn-primary"/>
                <Button text="⬇ Download" onAction="#handleDownload" styleClass="action-btn"/>
                <Button text="📤 Share" onAction="#handleShare" styleClass="action-btn"/>
                <Button text="✏ Rename" onAction="#handleRename" styleClass="action-btn"/>
                <Button text="➡ Move" onAction="#handleMoveFile" styleClass="action-btn"/>
                <Button fx:id="sortBtn" text="↕ Sort" onAction="#handleSort" styleClass="action-btn"/>
                <Button fx:id="createGroupBtn" text="👥 Create Group" onAction="#handleCreateGroup"
                        styleClass="action-btn" visible="false" managed="false"/>
                <Button fx:id="addGroupMemberBtn" text="➕ Add Member" onAction="#handleAddGroupMember"
                        styleClass="action-btn" visible="false" managed="false"/>
                <Button text="🗑 Delete" onAction="#handleDelete" styleClass="action-btn-danger"/>
            </HBox>

            <!-- Bookmarks bar -->
            <HBox fx:id="bookmarksBar" spacing="6" alignment="CENTER_LEFT" styleClass="bookmarks-bar">
                <Label text="⭐" styleClass="bookmarks-icon"/>
                <ScrollPane fx:id="bookmarksScroll" hbarPolicy="NEVER" vbarPolicy="NEVER"
                            fitToHeight="true" HBox.hgrow="ALWAYS" styleClass="bookmarks-scroll">
                    <HBox fx:id="bookmarkButtonsBox" spacing="5" alignment="CENTER_LEFT" styleClass="bookmarks-buttons-box"/>
                </ScrollPane>
                <Button text="+ Bookmark" onAction="#handleAddBookmark" styleClass="bookmark-add-btn"/>
            </HBox>

            <!-- Progress bar -->
            <VBox styleClass="progress-section" spacing="4">
                <ProgressBar fx:id="uploadProgressBar" prefWidth="99999"
                             progress="0" visible="false" managed="false"
                             styleClass="upload-progress"/>
                <Label fx:id="progressLabel" text="" styleClass="progress-label"
                       visible="false" managed="false"/>
            </VBox>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- FILE BROWSER VIEW                                               -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <HBox fx:id="fileView" spacing="0" VBox.vgrow="ALWAYS">

                <!-- Table container: tabs swap their TableView here -->
                <VBox fx:id="tableContainer" HBox.hgrow="ALWAYS" spacing="0" VBox.vgrow="ALWAYS"/>


                <!-- Preview / Discussion panel -->
                <!-- Preview / Discussion panel -->
                <StackPane>

                    <!-- NORMAL PREVIEW (default) -->
                    <VBox fx:id="previewPanel" styleClass="preview-panel" spacing="12"
                          alignment="TOP_CENTER" prefWidth="240">
                        <Label text="PREVIEW" styleClass="preview-title"/>
                        <ImageView fx:id="imagePreview" fitWidth="200" fitHeight="200"
                                   preserveRatio="true" visible="false"/>
                        <Label fx:id="previewLabel" text="Select a file to preview"
                               styleClass="preview-hint" wrapText="true"/>
                    </VBox>

                    <!-- DISCUSSION PANEL (shown when comment button clicked) -->
                    <VBox fx:id="discussionPanel" visible="false" managed="false"
                          spacing="0" prefWidth="320" styleClass="discussion-panel">

                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="discussion-header">
                            <Label text="💬" style="-fx-font-size: 13px;"/>
                            <Label fx:id="discussionTitleLabel" text="Discussion" styleClass="discussion-title" wrapText="true"/>
                            <Pane HBox.hgrow="ALWAYS"/>
                            <Button text="✕" onAction="#handleCloseDiscussion" styleClass="discussion-close-btn"/>
                        </HBox>

                        <!-- Scrollable content -->
                        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" styleClass="discussion-scroll">
                            <VBox spacing="10" style="-fx-padding: 12;">

                                <!-- Description -->
                                <Label text="Description" styleClass="discussion-section-label"/>
                                <TextArea fx:id="discussionDescArea" promptText="Add a description..." prefHeight="70" wrapText="true" styleClass="discussion-desc-area"/>
                                <Button text="Save Description" onAction="#handleSaveDescription" maxWidth="Infinity" styleClass="discussion-action-btn"/>

                                <!-- Comments label -->
                                <Label text="Comments" styleClass="discussion-section-label"/>

                                <!-- Comment bubbles go here dynamically -->
                                <VBox fx:id="commentsBox" spacing="6"/>

                            </VBox>
                        </ScrollPane>

                        <!-- Comment input fixed at bottom -->
                        <HBox spacing="6" styleClass="comment-input-bar">
                            <TextField fx:id="commentInputField" promptText="Write a comment..." HBox.hgrow="ALWAYS" styleClass="discussion-input-field"/>
                            <Button text="Send" onAction="#handleSendComment" styleClass="discussion-send-btn"/>
                        </HBox>

                    </VBox>

                </StackPane>

            </HBox>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- VIDEO PLAYER VIEW                                               -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <VBox fx:id="videoView" VBox.vgrow="ALWAYS" visible="false" managed="false" styleClass="video-view">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="viewer-header">
                    <Label text="🎬" style="-fx-font-size: 16px;"/>
                    <Label fx:id="videoTitleLabel" text="" styleClass="viewer-title"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="◀ Back to Files" onAction="#handleBackFromVideo" styleClass="viewer-action-btn"/>
                </HBox>

                <!-- Video display -->
                <StackPane VBox.vgrow="ALWAYS" maxHeight="380" styleClass="video-display">
                    <MediaView fx:id="mediaView" preserveRatio="true"/>
                </StackPane>

                <!-- Seek bar -->
                <VBox styleClass="viewer-seek-bar">
                    <Slider fx:id="seekSlider" min="0" value="0" styleClass="viewer-slider"/>
                    <HBox>
                        <Label fx:id="currentTimeLabel" text="00:00" styleClass="viewer-subtext"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalTimeLabel" text="00:00" styleClass="viewer-subtext"/>
                    </HBox>
                </VBox>

                <!-- Playback controls -->
                <HBox alignment="CENTER" spacing="12" styleClass="video-control-bar">
                    <Button text="⏮ -10s" onAction="#handleVideoRewind" styleClass="viewer-action-btn"/>
                    <Button fx:id="playPauseBtn" text="▶" onAction="#handleVideoPlayPause" styleClass="viewer-play-btn"/>
                    <Button text="+10s ⏭" onAction="#handleVideoForward" styleClass="viewer-action-btn"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button fx:id="muteBtn" text="🔊" onAction="#handleVideoMute" styleClass="viewer-icon-btn"/>
                    <Slider fx:id="volumeSlider" min="0" max="100" value="80" prefWidth="100" styleClass="viewer-slider"/>
                </HBox>

            </VBox>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- IMAGE VIEWER                                                    -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <VBox fx:id="imageView" VBox.vgrow="ALWAYS" visible="false" managed="false" styleClass="image-view">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="viewer-header">
                    <Label text="🖼" style="-fx-font-size: 16px;"/>
                    <Label fx:id="imageTitleLabel" text="" styleClass="viewer-title"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Button text="🖥 Open Externally" onAction="#handleOpenImageExternal" styleClass="viewer-action-btn"/>
                    <Button text="◀ Back to Files" onAction="#handleBackFromImage" styleClass="viewer-action-btn"/>
                    <Button text="◀ Prev" onAction="#handlePdfPrevPage" styleClass="viewer-action-btn"/>
                    <Button text="Next ▶" onAction="#handlePdfNextPage" styleClass="viewer-action-btn"/>
                </HBox>

                <!-- Image display area -->
                <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" fitToHeight="false" styleClass="image-scroll">
                    <StackPane styleClass="image-display" minWidth="400" minHeight="300" alignment="CENTER">
                        <ImageView fx:id="imageViewFull" preserveRatio="true"/>
                    </StackPane>
                </ScrollPane>

                <!-- Zoom controls -->
                <HBox alignment="CENTER" spacing="12" styleClass="video-control-bar">
                    <Button text="🔍−" onAction="#handleZoomOut" styleClass="viewer-action-btn"/>
                    <Slider fx:id="zoomSlider" min="10" max="400" value="100" prefWidth="200" styleClass="viewer-slider"/>
                    <Button text="🔍+" onAction="#handleZoomIn" styleClass="viewer-action-btn"/>
                    <Button text="⊡ Reset" onAction="#handleZoomReset" styleClass="viewer-action-btn"/>
                    <Label fx:id="zoomLabel" text="100%" styleClass="viewer-subtext"/>
                </HBox>

            </VBox>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- PDF VIEWER                                                      -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <VBox fx:id="pdfView" VBox.vgrow="ALWAYS" visible="false" managed="false" styleClass="pdf-view">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="viewer-header">
                    <Label text="📕" style="-fx-font-size: 16px;"/>
                    <Label fx:id="pdfTitleLabel" text="" styleClass="viewer-title"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label fx:id="pdfPageLabel" text="" styleClass="viewer-subtext"/>
                    <Button text="🖥 Open Externally" onAction="#handleOpenPdfExternal" styleClass="viewer-action-btn"/>
                    <Button text="◀ Back to Files" onAction="#handleBackFromPdf" styleClass="viewer-action-btn"/>
                </HBox>

                <!-- WebView renders the PDF via browser's built-in renderer -->
                <WebView fx:id="pdfWebView" VBox.vgrow="ALWAYS"/>

            </VBox>

        </VBox>
    </center>

</BorderPane>
